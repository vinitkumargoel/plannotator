{
  "name": "@plannotator/server",
  "version": "0.19.0",
  "private": true,
  "description": "Shared server implementation for Plannotator plugins",
  "main": "index.ts",
  "types": "index.ts",
  "exports": {
    ".": "./index.ts",
    "./review": "./review.ts",
    "./annotate": "./annotate.ts",
    "./home": "./home.ts",
    "./remote": "./remote.ts",
    "./browser": "./browser.ts",
    "./storage": "./storage.ts",
    "./git": "./git.ts",
    "./p4": "./p4.ts",
    "./vcs": "./vcs.ts",
    "./repo": "./repo.ts",
    "./share-url": "./share-url.ts",
    "./sessions": "./sessions.ts",
    "./project": "./project.ts",
    "./pr": "./pr.ts"
  },
  "files": [
    "*.ts"
  ],
  "dependencies": {
    "@plannotator/shared": "workspace:*",
    "@plannotator/ai": "workspace:*"
  },
  "peerDependencies": {
    "bun": ">=1.0.0"
  }
}
